# Copy this file to .env and fill in your values
# Never commit .env to git!

# GitHub PAT — used as API key for GitHub Models (free)
# Get from: github.com/settings/tokens -> Generate new token (classic)
ANTHROPIC_API_KEY=ghp_your_github_pat_here

# GitHub Models settings
MODEL=openai/gpt-4.1
TEMPERATURE=0.7
MAX_TOKENS=8096
OPENAI_BASE_URL=https://models.github.ai/inference

# SQLite memory database path
DB_PATH=chatbot_memory.db

# Gemini API key — used for code review (optional, falls back to programmatic patches)
# Get from: aistudio.google.com -> Get API key
GEMINI_API_KEY=your_gemini_api_key_here